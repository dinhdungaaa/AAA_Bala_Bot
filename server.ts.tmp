  res.json(botFaqs);
});

app.post("/api/bots/:botId/suggest-category", async (req, res) => {
  const { question, answer } = req.body;
  if (!question) {
    return res.status(400).json({ error: "CÃ¢u há»i lÃ  báº¯t buá»™c Ä‘á»ƒ cÃ³ thá»ƒ gá»£i Ã½ phÃ¢n nhÃ³m." });
  }

  const ai = getAIClient();
  if (!ai) {
    return res.json({ category: "faq", confidence: "low", reason: "AI Service is khÃ´ng hoáº¡t Ä‘á»™ng." });
  }

  try {
    const prompt = `PhÃ¢n tÃ­ch cÃ¢u há»i vÃ  cÃ¢u tráº£ lá»i sau Ä‘Ã¢y Ä‘á»ƒ chá»n nhÃ³m tri thá»©c phÃ¹ há»£p nháº¥t tá»« danh sÃ¡ch cho trÆ°á»›c dÆ°á»›i Ä‘Ã¢y.

CÃ¢u há»i: "${question}"
CÃ¢u tráº£ lá»i: "${answer || 'ChÆ°a cung cáº¥p cÃ¢u tráº£ lá»i chi tiáº¿t'}"

Danh sÃ¡ch cÃ¡c nhÃ³m chia sáºµn (chá»n duy nháº¥t 1 nhÃ³m):
1. "product": Vá» Ä‘áº·c tÃ­nh sáº£n pháº©m, cháº¥t liá»‡u, tÃ­nh nÄƒng, cÃ¡ch sá»­ dá»¥ng, nguá»“n gá»‘c xuáº¥t xá»©, thÃ´ng sá»‘ ká»¹ thuáº­t.
2. "pricing": Vá» giÃ¡ cáº£, báº£ng giÃ¡ sá»‰/láº», chÆ°Æ¡ng trÃ¬nh Æ°u Ä‘Ã£i, khuyáº¿n mÃ£i, mÃ£ giáº£m giÃ¡, quÃ  táº·ng kÃ¨m, bÃ¡o giÃ¡ sá»‰ Ä‘áº¡i lÃ½.
3. "policy": Vá» chÃ­nh sÃ¡ch Ä‘á»•i tráº£, quy Ä‘á»‹nh thu há»“i, quyá»n lá»£i khiáº¿u náº¡i, cam káº¿t hoÃ n tiá»n.
4. "shipping": Vá» dá»‹ch vá»¥ váº­n chuyá»ƒn, giao hÃ ng há»a tá»‘c, bÃ¡n kÃ­nh ship hÃ ng, phÃ­ ship, khu vá»±c nháº­n hÃ ng.
5. "warranty": Vá» thá»i háº¡n báº£o hÃ nh, Ä‘Äƒng kÃ½ kÃ­ch hoáº¡t báº£o hÃ nh, báº£o dÆ°á»¡ng Ä‘á»‹nh ká»³ hoáº·c chÃ­nh sÃ¡ch há»— trá»£ ká»¹ thuáº­t dÃ i lÃ¢u.
6. "faq": CÃ¢u há»i thÆ°á»ng gáº·p chung, cÃ¢u xÃ£ giao, chÃ o há»i, hoáº·c khÃ´ng thuá»™c cÃ¡c chá»§ Ä‘á» trÃªn.

Yáº¾U Cáº¦U Äá»ŠNH Dáº NG Äáº¦U RA: Tráº£ vá» má»™t chuá»—i JSON há»£p lá»‡ cÃ³ dáº¡ng duy nháº¥t:
{
  "category": "mÃ£_nhÃ³m_tiáº¿ng_anh",
  "reason": "giáº£i thÃ­ch ngáº¯n gá»n tá»‘i Ä‘a 15 tá»« lÃ½ do chá»n nhÃ³m nÃ y báº±ng tiáº¿ng Viá»‡t",
  "confidence": "high"
}
LÆ°u Ã½ mÃ£_nhÃ³m_tiáº¿ng_anh chá»‰ Ä‘Æ°á»£c lÃ  1 trong 6 mÃ£: "product", "pricing", "policy", "shipping", "warranty", "faq". Tráº£ vá» Ä‘á»‹nh dáº¡ng JSON thuáº§n vÄƒn báº£n, khÃ´ng bá»c khá»‘i code markdown \`\`\`json.`;

    const response = await ai.models.generateContent({
      model: "gemini-3.5-flash",
      contents: prompt,
    });

