# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE_URL: Your Supabase Project URL (e.g. https://xyz.supabase.co)
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=

# SUPABASE_ANON_KEY: Your Supabase API Anon Key
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# SUPABASE_SERVICE_ROLE_KEY: Optional Supabase Service Role Key for admin backend access (recommended)
SUPABASE_SERVICE_ROLE_KEY=

# FACEBOOK_VERIFY_TOKEN: Any private string you choose; paste the same value into Meta webhook verification.
FACEBOOK_VERIFY_TOKEN="balabot-dev-verify-token"

# FACEBOOK_PAGE_ACCESS_TOKEN: Page access token for the Facebook Page connected to this dev bot.
# Required only when sending real replies back through Messenger.
FACEBOOK_PAGE_ACCESS_TOKEN=

# FACEBOOK_GRAPH_API_VERSION: Optional Meta Graph API version override.
FACEBOOK_GRAPH_API_VERSION="v25.0"

# Facebook OAuth (app chung BalaBot — kết nối Fanpage 1 chạm)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# BOTPRESS_API_SECRET: Optional shared secret for Botpress HTTP calls to /api/integrations/botpress/reply.
BOTPRESS_API_SECRET="change-me-before-production"

# Zalo Group Bot (Huong B - khong chinh thuc, dung nick phu)
ZALO_GROUP_BOT_ENABLED=false
ZALO_ACCOUNT_LABEL=default
ZALO_RATE_LIMIT_PER_MIN=5

# Botcake bridge — origin công khai của backend (mặc định URL Railway production)
PUBLIC_BACKEND_ORIGIN=

